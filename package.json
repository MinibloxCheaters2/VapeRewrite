    "build:prod": "cross-env NODE_ENV=production run-s ci build:js",
    "build": "cross-env NODE_ENV=production run-s clean build:prod",
    "devbuild": "run-s clean dev",
    "lint": "biome check",
    "lint:fix": "biome check --fix"
  },
  "dependencies": {
    "@violentmonkey/dom": "^2.2.1",
    "@wq2/brigadier-ts": "^1.0.8",
