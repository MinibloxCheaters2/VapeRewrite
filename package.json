		"patch-package": "^8.0.1",
		"postcss": "^8.5.6",
		"postcss-calc": "^10.1.1",
		"postcss-nested": "^7.0.2",
		"read-package-up": "^12.0.0",
		"rolldown-plugin-userscript": "../rolldown-plugin-userscript",
		"socket.io-client": "^4.8.3",
		"typescript": "^5.9.3",
		"unocss": "^66.6.2",
		"@biomejs/biome": "^2.4.4"
	},
	"lint-staged": {
		"*.{ts,tsx,js,css}": [
			"biome check --fix"
