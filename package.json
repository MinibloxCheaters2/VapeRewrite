    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/three": "0.158.3",
    "@violentmonkey/types": "^0.3.2",
    "@wq2/rolldown-plugin-solid-oxc": "^0.1.0-alpha.16",
    "@wq2/solid-jsx-oxc": "^0.1.0-alpha.15",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "lint-staged": "^16.3.0",
    "npm-run-all": "^4.1.5",
    "read-package-up": "^12.0.0",
    "@wq2/rolldown-plugin-swc": "^0.0.2",
    "rolldown-plugin-userscript": "1.1.1",
    "socket.io-client": "^4.8.3",
